  "suiteName": "Create Lead - Lead Management",
  "case": {
    "id": "e2e-lead-validation-errors",
    "title": "E2E: Attempt to create Lead with missing mandatory fields and verify errors",
    "priority": "P1",
    "platforms": [
      "chrome"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to Salesforce Leads tab",
        "locatorHint": "Leads tab URL",
        "value": "https://login.salesforce.com/leads"
      },
      {
        "id": "step2",
        "action": "tap",
        "targetDescription": "Click on 'New' button",
        "locatorHint": "button[name='New']"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Click on 'Save' button without entering any fields",
        "locatorHint": "button[name='Save']"
      },
      {
        "id": "step4",
        "action": "assertVisible",
        "targetDescription": "Verify validation error for Last Name",
        "locatorHint": "div[data-testid='lastname-error']"
      },
      {
        "id": "step5",
        "action": "assertVisible",
        "targetDescription": "Verify validation error for Company",
        "locatorHint": "div[data-testid='company-error']"
      }
    ],
    "tags": [
      "@e2e",
      "@regression",
      "lead"
    ]
  }
}
